<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.opensabre.admin.dao.mapper.HotelOrderItemMapper">

    <!-- 查询某订单的所有明细 -->
    <select id="selectByOrderId" resultType="com.opensabre.admin.dao.entity.po.HotelOrderItem">
        SELECT * FROM hotel_order_item
        WHERE order_id = #{orderId}
    </select>

</mapper>
